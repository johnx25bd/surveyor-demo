# Anthropic API key — used by the agent loop (added when the loop lands).
ANTHROPIC_API_KEY=

# OS Data Hub API key — used by fetch_features against the OS NGD Features API, and reused by the
# basemap proxy for the OS Vector Tile API. Sent server-side only; never reaches the browser.
OS_DATA_HUB_KEY=

# Optional: a separate key for the OS Vector Tile basemap. Set this only if the basemap lives on a
# different OS Data Hub project than the NGD features key above; otherwise OS_DATA_HUB_KEY is reused.
# OS_MAPS_API_KEY=

# Nomis and the ONS/MHCLG ArcGIS services need no key.
