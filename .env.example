# Anthropic API key — used by the agent loop (added when the loop lands).
ANTHROPIC_API_KEY=

# OS Data Hub API key — used by fetch_features against the OS NGD Features API.
# Sent as the `key` request header; never reaches the browser.
OS_DATA_HUB_KEY=

# Nomis and the ONS/MHCLG ArcGIS services need no key.
